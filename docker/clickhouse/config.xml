<?xml version="1.0"?>
<clickhouse>
    <!-- Listen on all interfaces inside Docker (IPv4 only, IPv6 disabled in WSL) -->
    <listen_host>0.0.0.0</listen_host>
    <listen_try>1</listen_try>

    <!-- Logging -->
    <logger>
        <level>warning</level>
        <console>1</console>
    </logger>

    <!-- HTTP interface -->
    <http_port>8123</http_port>
    <!-- Native TCP interface -->
    <tcp_port>9000</tcp_port>

    <!-- Data storage -->
    <path>/var/lib/clickhouse/</path>
    <tmp_path>/var/lib/clickhouse/tmp/</tmp_path>

    <!-- Mark cache — kept small for low-RAM servers (128 MB) -->
    <mark_cache_size>134217728</mark_cache_size>

    <!-- Max connections -->
    <max_connections>100</max_connections>
    <keep_alive_timeout>10</keep_alive_timeout>

    <!-- Memory limits — cap ClickHouse at 30% of RAM (~600 MB on a 2 GB server) -->
    <max_server_memory_usage_to_ram_ratio>0.3</max_server_memory_usage_to_ram_ratio>

    <!-- Limit concurrent queries -->
    <max_concurrent_queries>20</max_concurrent_queries>

    <!-- Timezone -->
    <timezone>UTC</timezone>

    <!-- Disable telemetry -->
    <send_crash_reports>
        <enabled>false</enabled>
    </send_crash_reports>
</clickhouse>
