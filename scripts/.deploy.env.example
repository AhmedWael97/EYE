# Copy to scripts/.deploy.env (gitignored) and fill in your server details.
# Used by scripts/remote-deploy.sh to trigger a deploy over SSH.
VPS_HOST=your.server.ip
VPS_USER=deploy
VPS_PATH=/srv/eye
VPS_PORT=22
# Optional: path to the private key for that server (else uses your ssh-agent / default key)
# VPS_SSH_KEY=~/.ssh/eye_deploy
